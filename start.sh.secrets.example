# /etc/herb-pusher-secrets.env
# Copy to: /etc/herb-pusher-secrets.env
# Permissions: chmod 600 /etc/herb-pusher-secrets.env
# This file NEVER goes in git.

# PostgreSQL
POSTGRES_DB=herb_pusher
POSTGRES_USER=herb_pusher_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Payload CMS — any 32+ character random string
PAYLOAD_SECRET=REPLACE_WITH_STRONG_SECRET

# Meilisearch
MEILISEARCH_MASTER_KEY=REPLACE_WITH_STRONG_KEY
MEILISEARCH_API_KEY=REPLACE_WITH_STRONG_KEY

# Cloudflare R2
R2_BUCKET=theherbpusher-media
R2_ENDPOINT=https://ef4c58ff9550a94aec11e81607fe7572.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=72788a308a22395fede46bc192291bcd
R2_SECRET_ACCESS_KEY=31d73df46d320a7a15d55ec87862294acafbcfd531632a0707e2777d8d84ddb1

# Site URL
NEXT_PUBLIC_SITE_URL=https://theherbpusher.com

# Meilisearch host (internal Docker network)
MEILISEARCH_HOST=http://search:7700

# MailerLite (optional — leave blank to disable newsletter)
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
