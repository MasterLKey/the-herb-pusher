# Non-sensitive config — safe to commit
# Secrets (POSTGRES_PASSWORD, PAYLOAD_SECRET, etc.) are stored in Infisical — never here

POSTGRES_DB=herb_pusher
POSTGRES_USER=herb_pusher_user

# Public site URL
NEXT_PUBLIC_SITE_URL=https://theherbpusher.com

# Meilisearch (host — key comes from Infisical)
MEILISEARCH_HOST=http://search:7700

# Cloudflare R2 (bucket/endpoint — keys come from Infisical)
R2_BUCKET=theherbpusher-media
R2_ENDPOINT=https://ef4c58ff9550a94aec11e81607fe7572.r2.cloudflarestorage.com

# MailerLite (API key comes from secrets file)
MAILERLITE_GROUP_ID=

# Analytics (optional — leave blank to disable)
# Plausible: set to your domain, e.g. theherbpusher.com
PLAUSIBLE_DOMAIN=
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
GA_MEASUREMENT_ID=

# Secrets managed via Infisical / /etc/herb-pusher-secrets.env (DO NOT commit values):
# POSTGRES_PASSWORD
# PAYLOAD_SECRET
# MEILISEARCH_MASTER_KEY
# MEILISEARCH_API_KEY
# R2_ACCESS_KEY_ID
# R2_SECRET_ACCESS_KEY
# MAILERLITE_API_KEY
