# Non-sensitive config — safe to commit
# Secrets (POSTGRES_PASSWORD, PAYLOAD_SECRET, etc.) are stored in Infisical — never here

POSTGRES_DB=herb_pusher
POSTGRES_USER=herb_pusher_user

# Public site URL
NEXT_PUBLIC_SITE_URL=https://theherbpusher.com

# Meilisearch (host — key comes from Infisical)
MEILISEARCH_HOST=http://search:7700

# Cloudflare R2 (bucket/endpoint — keys come from Infisical)
R2_BUCKET=herb-pusher-media
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# MailerLite (API key comes from Infisical)
MAILERLITE_GROUP_ID=

# Secrets managed via Infisical (DO NOT commit values):
# POSTGRES_PASSWORD
# PAYLOAD_SECRET
# MEILISEARCH_MASTER_KEY
# MEILISEARCH_API_KEY
# R2_ACCESS_KEY_ID
# R2_SECRET_ACCESS_KEY
# MAILERLITE_API_KEY
